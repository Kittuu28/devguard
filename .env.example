# =============================================================================
# DevGuard — Environment Variables
# Copy this file to .env.local and fill in all values
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider
# Get your key at: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Auth0 Configuration
# Get these from: Auth0 Dashboard → Applications → Your App → Settings
# -----------------------------------------------------------------------------
AUTH0_DOMAIN=                        # e.g. your-tenant.jp.auth0.com
AUTH0_CLIENT_ID=                     # From Basic Information section
AUTH0_CLIENT_SECRET=                 # From Basic Information section
AUTH0_SECRET=                        # Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH0_AUDIENCE=https://devguard.local/api   # Your custom API identifier in Auth0
AUTH0_SCOPE=openid profile email offline_access

# -----------------------------------------------------------------------------
# Auth0 Management API Token
# Get from: Auth0 Dashboard → Applications → APIs → Auth0 Management API → API Explorer
# Note: This token expires — regenerate if you get 401 errors
# -----------------------------------------------------------------------------
AUTH0_MGMT_TOKEN=

# -----------------------------------------------------------------------------
# App URL
# Use http://localhost:3000 for local development
# Use your Vercel URL for production
# -----------------------------------------------------------------------------
APP_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# LangGraph Server
# Leave as-is for local development
# Replace with your hosted LangGraph URL for production
# -----------------------------------------------------------------------------
LANGGRAPH_API_URL=http://localhost:54367

# -----------------------------------------------------------------------------
# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens → Generate new token (classic)
# Required scopes: repo, read:org, read:user
# Note: In production this is replaced by Auth0 Token Vault
# -----------------------------------------------------------------------------
GITHUB_PAT=

# -----------------------------------------------------------------------------
# Slack Bot Token
# Get from: https://api.slack.com/apps → Your App → OAuth & Permissions
# Required scopes: chat:write, channels:read, channels:join
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Database (optional - only needed for document features)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_documents_db

# -----------------------------------------------------------------------------
# LangChain (optional - for tracing)
# -----------------------------------------------------------------------------
LANGCHAIN_CALLBACKS_BACKGROUND=false
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=devguard
